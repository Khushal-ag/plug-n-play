{
  "name": "cms",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,mdx,json}\" \"README.md\" \"docs/**/*.md\" --cache",
    "fmt": "prettier --write \"**/*.{ts,tsx,mdx,json}\" \"README.md\" \"docs/**/*.md\" --cache --experimental-ternaries",
    "clean": "rm -rf .next",
    "cleani": "rm -rf .next && rm -rf node_modules && bun install",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "node ./node_modules/drizzle-kit/bin.cjs studio",
    "cms:sync": "node cms/sync-routes.mjs",
    "cms:install": "node cms/install.mjs",
    "prepare": "husky",
    "validate": "eslint . && tsc --noEmit && prettier --check \"**/*.{ts,tsx,mdx,json}\" \"README.md\" \"docs/**/*.md\" --cache && next build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,mdx,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@uiw/codemirror-theme-github": "^4.25.8",
    "@uiw/react-codemirror": "^4.25.8",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-ebf51a3-20250411",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "^19.0.0-beta-ebf51a3-20250411",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-animate": "^0.2.10",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "zod-validation-error": "^5.0.0"
  }
}
